# Microsoft Sentinel MCP detection-engine server. Copy to `.env` and fill in real values.
# See README.md for setup details (cert generation, App Registration, permissions, workspace ID).
# NEVER commit `.env`.

# --- Single-tenant mode ---

AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CERT_PATH=/absolute/path/to/app-cert.pfx
# AZURE_CERT_PASSPHRASE=

# Log Analytics workspace GUID (required for `dry_run_kql`).
SENTINEL_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --- Multi-tenant mode (overrides the single-tenant vars above) ---
# See tenants.example.json for the file schema. File must be 0600 on POSIX.
# MCP_SENTINEL_TENANTS_FILE=/etc/mcp-sentinel-detection-engine/tenants.json

# --- Optional tuning ---
# LOGANALYTICS_API_BASE=https://api.loganalytics.io
# MCP_SENTINEL_LOG_LEVEL=INFO
